{
  "exclude": ["node_modules", "**/.*/"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "incremental": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "isolatedModules": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true
  }
}
