{
  "name": "goothe",
  "version": "0.1.0",
  "private": true,
  "description": "Streamlined booking UI for Bay View Bark (goose.pet)",
  "license": "MIT",
  "repository": "github:jgeurts/goothe",
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "22.16.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.3"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint src --tsconfig tsconfig.json",
    "lint:fix": "oxlint src --tsconfig tsconfig.json --fix",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "typecheck": "tsc --noEmit"
  },
  "browserslist": [
    ">0.5%",
    "not dead",
    "not OperaMini all"
  ]
}
